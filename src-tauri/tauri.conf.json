{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "OmniSearch",
    "version": "0.1.0",
    "identifier": "com.omnisearch.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "OmniSearch",
                "width": 820,
                "height": 600,
                "resizable": false,
                "fullscreen": false,
                "center": true,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": true,
                "visible": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "globalShortcut": {
            "shortcuts": {}
        }
    }
}