{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "OmniSearch",
    "version": "0.1.0",
    "identifier": "com.omnisearch.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build",
        "devUrl": "http://localhost:5173",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "OmniSearch",
                "width": 900,
                "height": 650,
                "resizable": true,
                "fullscreen": false,
                "center": true,
                "decorations": false,
                "transparent": true,
                "alwaysOnTop": true,
                "skipTaskbar": false,
                "visible": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "plugins": {
        "shell": {
            "open": true
        },
        "globalShortcut": {
            "shortcuts": {}
        }
    }
}